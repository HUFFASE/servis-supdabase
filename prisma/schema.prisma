datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  Direktor    @map("Direktör")
  Mudur       @map("Müdür")
  Presales
  Postsales
}

enum CaseSeverity {
  Critical
  High
  Medium
  Low
}

enum CaseStatus {
  Open
  InProgress        @map("In Progress")
  Resolved
  Closed
  AwaitingCustomer  @map("Awaiting Customer")
  AwaitingVendor    @map("Awaiting Vendor")
}

enum ContractStatus {
  Active
  Pending
  Expired
}

enum OneOffStatus {
  Draft
  InProgress        @map("In Progress")
  Completed
}

enum CertStatus {
  Active
  Expiring
  Expired
}

enum SparePartStatus {
  InStock
  Out
}

enum TimesheetStatus {
  Draft
  Submitted
  Approved
  Rejected
}

model Profile {
  id           String          @id
  full_name    String
  email        String          @unique
  role         UserRole        @default(Postsales)
  avatar_url   String?
  hourly_cost  Decimal         @default(50.0) @db.Decimal(10, 2)
  password     String          @default("123456")
  updated_at   DateTime        @default(now()) @updatedAt
  certificates Certificate[]
  cases        Case[]          @relation("AssignedTo")
  timesheets   Timesheet[]
  approved_ts  Timesheet[]     @relation("ApprovedBy")
  articles     KnowledgeArticle[]

  @@map("profiles")
}

model Brand {
  id          String                  @id
  name        String                  @unique
  logo_url    String?
  description String?
  updated_at  DateTime                @default(now()) @updatedAt
  services    Service[]
  cert_defs   CertificateDefinition[]
  certs       Certificate[]
  parts       SparePart[]
  articles    KnowledgeArticle[]

  @@map("brands")
}

model Service {
  id             String             @id
  name           String
  brand_id       String?
  brand          Brand?             @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  description    String?
  price_per_hour Decimal            @default(0.0) @db.Decimal(10, 2)
  updated_at     DateTime           @default(now()) @updatedAt
  articles       KnowledgeArticle[]

  @@map("services")
}

model CertificateDefinition {
  id         String   @id
  name       String
  brand_id   String?
  brand      Brand?   @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  updated_at DateTime @default(now()) @updatedAt

  @@unique([name, brand_id])
  @@map("certificate_definitions")
}

model Certificate {
  id          String     @id
  name        String
  brand_id    String?
  brand       Brand?     @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  profile_id  String?
  profile     Profile?   @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  issue_date  DateTime   @db.Date
  expiry_date DateTime   @db.Date
  status      CertStatus @default(Active)
  updated_at  DateTime   @default(now()) @updatedAt

  @@map("certificates")
}

model Customer {
  id             String     @id
  name           String     @unique
  industry       String
  contact_person String
  email          String
  phone          String
  updated_at     DateTime   @default(now()) @updatedAt
  contracts      Contract[]
  oneoffs        OneOff[]
  cases          Case[]

  @@map("customers")
}

model Contract {
  id          String         @id
  customer_id String?
  customer    Customer?      @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  name        String
  start_date  DateTime       @db.Date
  end_date    DateTime       @db.Date
  value       Decimal        @default(0.0) @db.Decimal(15, 2)
  sla_details String?
  status      ContractStatus @default(Active)
  updated_at  DateTime       @default(now()) @updatedAt
  cases       Case[]

  @@map("contracts")
}

model OneOff {
  id          String       @id
  customer_id String?
  customer    Customer?    @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  name        String
  amount      Decimal      @default(0.0) @db.Decimal(15, 2)
  status      OneOffStatus @default(Draft)
  updated_at  DateTime     @default(now()) @updatedAt
  parts       SparePart[]
  timesheets  Timesheet[]

  @@map("oneoffs")
}

model Case {
  id                  String         @id
  customer_id         String?
  customer            Customer?      @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  contract_id         String?
  contract            Contract?      @relation(fields: [contract_id], references: [id], onDelete: SetNull)
  title               String
  description         String?
  severity            CaseSeverity   @default(Medium)
  status              CaseStatus     @default(Open)
  assigned_to         String?
  assignee            Profile?       @relation("AssignedTo", fields: [assigned_to], references: [id], onDelete: SetNull)
  created_at          DateTime       @default(now())
  sla_countdown_hours Decimal        @default(24.0) @db.Decimal(5, 2)
  comments            CaseComment[]
  timesheets          Timesheet[]
  feedback            CaseFeedback?

  @@map("cases")
}

model CaseComment {
  id         String   @id
  case_id    String?
  case       Case?    @relation(fields: [case_id], references: [id], onDelete: Cascade)
  author     String
  text       String
  date       DateTime @default(now())

  @@map("case_comments")
}

model AppNotification {
  id        String   @id
  title     String
  message   String
  severity  String   @default("info")
  timestamp DateTime @default(now())
  read      Boolean  @default(false)

  @@map("notifications")
}

model SparePart {
  id             String          @id
  name           String
  part_code      String?
  serial_number  String?
  brand_id       String?
  brand          Brand?          @relation(fields: [brand_id], references: [id], onDelete: SetNull)
  project_id     String?
  project        OneOff?         @relation(fields: [project_id], references: [id], onDelete: SetNull)
  is_pool        Boolean         @default(false)
  stock_in_date  DateTime        @db.Date
  stock_out_date DateTime?       @db.Date
  status         SparePartStatus @default(InStock)
  notes          String?
  created_at     DateTime        @default(now())
  updated_at     DateTime        @default(now()) @updatedAt

  @@map("spare_parts")
}

model Timesheet {
  id            String          @id
  profile_id    String
  profile       Profile         @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  case_id       String?
  case          Case?           @relation(fields: [case_id], references: [id], onDelete: SetNull)
  oneoff_id     String?
  oneoff        OneOff?         @relation(fields: [oneoff_id], references: [id], onDelete: SetNull)
  activity_date DateTime        @db.Date
  hours_spent   Decimal         @db.Decimal(5, 2)
  description   String
  is_billable   Boolean         @default(true)
  status        TimesheetStatus @default(Draft)
  approved_by   String?
  approver      Profile?        @relation("ApprovedBy", fields: [approved_by], references: [id], onDelete: SetNull)
  created_at    DateTime        @default(now())

  @@map("timesheets")
}

model CaseFeedback {
  id         String   @id
  case_id    String   @unique
  case       Case     @relation(fields: [case_id], references: [id], onDelete: Cascade)
  rating     Int
  comments   String?
  created_at DateTime @default(now())

  @@map("case_feedbacks")
}

model KnowledgeArticle {
  id            String    @id
  title         String
  content       String    @db.Text
  brand_id      String?
  brand         Brand?    @relation(fields: [brand_id], references: [id], onDelete: SetNull)
  service_id    String?
  service       Service?  @relation(fields: [service_id], references: [id], onDelete: SetNull)
  created_by    String?
  author        Profile?  @relation(fields: [created_by], references: [id], onDelete: SetNull)
  tags          String    @default("[]")
  views_count   Int       @default(0)
  helpful_votes Int       @default(0)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now()) @updatedAt

  @@map("knowledge_articles")
}
